APP_MODE=mvp
DEMO_MODE=false
DEMO_DAY=false

# Backend / frontend
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
INDEXER_DB=./indexer/data/atlas-index.sqlite

# Chain mode is canonical for deployed Agent Atlas
CHAIN_MODE=chain
RPC_URL=https://rpc.sepolia.mantle.xyz
# Keep false/empty in production. Enables legacy backend-signed writes only for local development.
ENABLE_SERVER_SIGNER=false
PRIVATE_KEY=
SEED_ON_DEPLOY=false
MANTLESCAN_API_KEY=
MANTLESCAN_API_URL=https://api-sepolia.mantlescan.xyz/api
MANTLE_EXPLORER_URL=https://sepolia.mantlescan.xyz

# Filled after deployment
AGENT_REGISTRY_ADDRESS=
JOB_MANAGER_ADDRESS=
PROOF_VERIFIER_ADDRESS=
ATLAS_SCORE_ADDRESS=
